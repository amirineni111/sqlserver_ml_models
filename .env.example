# Environment Variables for SQL Server Connection
# Copy this file to .env and update with your actual database credentials

# SQL Server Configuration
SQL_SERVER=your-server-name-or-ip
SQL_DATABASE=your-database-name
SQL_USERNAME=your-username
SQL_PASSWORD=your-password
SQL_DRIVER=ODBC Driver 17 for SQL Server

# Alternative: Use Windows Authentication (comment out username/password above)
# SQL_TRUSTED_CONNECTION=yes

# Connection Settings
SQL_TIMEOUT=30
SQL_POOL_SIZE=5
SQL_MAX_OVERFLOW=10

# Development Settings
DEBUG=True
LOG_LEVEL=INFO

# =============================================================================
# Sector Sentiment Analysis (Optional)
# =============================================================================
# NewsAPI key for sector sentiment collection (free tier: 100 req/day)
# Get your key at: https://newsapi.org/register
# Leave blank to use only RSS + GDELT (both free, unlimited)
# NEWSAPI_KEY=your_newsapi_key_here

# =============================================================================
# Remote Access from Machine B (SQL Server on Machine A)
# =============================================================================
# If running this repo on a different machine from SQL Server, uncomment and
# update the settings below. Replace <MachineA_IP> with Machine A's LAN IP.
#
# SQL_SERVER=192.168.86.55\MSSQLSERVER01
# SQL_DATABASE=stockdata_db
# SQL_TRUSTED_CONNECTION=no
# SQL_USERNAME=your_sql_login
# SQL_PASSWORD=your_sql_password
# SQL_DRIVER=ODBC Driver 17 for SQL Server
